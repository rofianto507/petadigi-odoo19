<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_petadigi_subdit_list" model="ir.ui.view">
            <field name="name">subdit.list.petadigi</field>
            <field name="model">petadigi.subdit</field>
            <field name="arch" type="xml">
                <list string="Subdit">
                    <field name="name"/>
                    <field name="keterangan"/>
                </list>
            </field>
        </record>

        <record id="view_petadigi_subdit_form" model="ir.ui.view">
            <field name="name">subdit.form.petadigi</field>
            <field name="model">petadigi.subdit</field>
            <field name="arch" type="xml">
                <form string="Subdit">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="keterangan"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_petadigi_subdit" model="ir.actions.act_window">
            <field name="name">Subdit</field>
            <field name="res_model">petadigi.subdit</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>

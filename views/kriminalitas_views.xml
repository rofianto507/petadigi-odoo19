<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_petadigi_kriminalitas_list" model="ir.ui.view">
            <field name="name">kriminalitas.list.petadigi</field>
            <field name="model">petadigi.kriminalitas</field>
            <field name="arch" type="xml">
                <list string="Data Kriminalitas">
                    <header>
                        <button name="action_open_import_wizard" 
                            string="Import LP" 
                            type="object" 
                            class="btn-secondary" 
                            display="always"/>
                    </header>
                    <field name="jenis_lp"/>
                    <field name="no_lp"/>
                    <field name="kategori_id"/>
                    <field name="sub_kategori_id"/>
                    <field name="tanggal_kejadian"/>
                    <field name="subdit_id"/>
                    <field name="polres_id"/>
                    <field name="status_perkara" widget="badge"
                        decoration-success="status_perkara == 'SELESAI'"
                        decoration-warning="status_perkara == 'PROSES'"/>
                </list>
                
            </field>
        </record>
        <!-- Search VIEW Kriminalitas -->
        <record id="view_petadigi_kriminalitas_search" model="ir.ui.view">
            <field name="name">kriminalitas.search.petadigi</field>
            <field name="model">petadigi.kriminalitas</field>
            <field name="arch" type="xml">
                <search string="Cari Data Kriminalitas">
                    <field name="no_lp"/>
                    <field name="tempat_kejadian"/>
                    <field name="pelapor"/>
                    <field name="terlapor"/>
                    <field name="tindak_pidana"/>
                    <separator/>                    
                    <filter string="Status PROSES" name="filter_status_proses" domain="[('status_perkara','=','PROSES')]" />
                    <filter string="Status SELESAI" name="filter_status_selesai" domain="[('status_perkara','=','SELESAI')]" />
                    <separator/>
                    <filter string="LP A" name="filter_lp_a" domain="[('jenis_lp','=','LP A')]" />
                    <filter string="LP B" name="filter_lp_b" domain="[('jenis_lp','=','LP B')]" />
                    <separator/>
                    <filter string="Tanggal Kejadian" name="filter_tanggal_kejadian" date="tanggal_kejadian"/>
                </search>
            </field>
        </record>
        <!-- FORM VIEW Kriminalitas -->
        <record id="view_petadigi_kriminalitas_form" model="ir.ui.view">
            <field name="name">kriminalitas.form.petadigi</field>
            <field name="model">petadigi.kriminalitas</field>
            <field name="arch" type="xml">
                <form string="Data Kriminalitas">
                    <sheet>
                        <group>
                            <field name="jenis_lp" widget="radio" no_label="1" options="{'horizontal': true}"/>
                            <field name="no_lp"/>
                            <field name="penanggung_jawab"/>
                            <field name="subdit_id"/>
                            <field name="sumber_dokumen_id"/>
                        </group>
                        <group>
                            <group string="KESATUAN">
                                <field name="polres_id"/>
                                <field name="polsek_id" domain="[('polres_id', '=', polres_id)]"/>
                            </group>
                            <group string="KATEGORI">
                                <field name="kategori_id"/>
                                <field name="sub_kategori_id" domain="[('kategori_kriminal_id', '=', kategori_id)]"/>
                            </group>
                        </group>
                        <group>
                            <group string="WILAYAH">
                                <field name="kabupaten_id"/>
                                <field name="kecamatan_id" domain="[('kabupaten_id', '=', kabupaten_id)]"/>
                                <field name="desa_id" domain="[('kecamatan_id', '=', kecamatan_id)]"/>
                            </group>
                            
                            <group string="STATUS PERKARA">
                                <field name="status_perkara"/>
                                <field name="sub_status_perkara_id" domain="[('status_perkara', '=', status_perkara)]"/>
                                <field name="is_perkara_selesai" invisible="1"/>
                                <field name="tanggal_selesai" invisible="not is_perkara_selesai"/>
                            </group>
                        </group>
                       
                            <div >
                                <field name="latitude" widget="latlong_map_picker" 
                                class="latlong-mappicker-wrapper"
                                    nolabel="1"/>
                            </div>
                       
                        <group>
                            <field name="latitude" string="Latitude"/>
                            <field name="longitude" string="Longitude"/>
                        </group>
                        <notebook>
                            <page string="Detail Informasi">
                                <group>
                                    <field name="pelapor" string="Pelapor"/>
                                </group>
                                <group string="PERISTIWA YANG TERJADI">  
                                    <field name="jenis_tkp_id" string="Jenis TKP"/>
                                    <field name="tanggal_kejadian" string="Waktu Kejadian"/> 
                                    <field name="tempat_kejadian" string="Tempat Kejadian"/>
                                    <field name="apa_yang_terjadi" string="Apa yang Terjadi"/>
                                    <field name="terlapor" string="Siapa Terlapor"/>
                                    <field name="korban" string="Siapa Korban"/>
                                    <field name="tanggal_laporan" string="Kapan Dilaporkan"/>
                                </group>
                                <group string="KETERANGAN LAINNYA">
                                    <field name="tindak_pidana" string="Tindak Pidana"/>
                                    <field name="saksi" string="Saksi"/>
                                    <field name="barang_bukti" string="Barang Bukti"/>
                                    <field name="uraian_singkat" string="Uraian Singkat"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ACTION Kriminalitas -->
        <record id="action_petadigi_kriminalitas" model="ir.actions.act_window">
            <field name="name">Kriminalitas</field>
            <field name="res_model">petadigi.kriminalitas</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="petadigi.view_petadigi_kriminalitas_search"/>
        </record>
    </data>
</odoo>
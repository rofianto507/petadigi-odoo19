<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View Form -->
    <record id="res_config_settings_view_form_content_gen" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.content.gen</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <!-- Setting Section -->
                <app data-string="Content Generator" string="Content Generator" name="content_generator">
                    <block title="AI Configuration" name="ai_config">
                        <setting string="Gemini AI">
                            <label for="gemini_api_key"/>
                            <div class="text-muted">
                                API Key required to generate content with Google Gemini AI.
                            </div>
                            <field name="gemini_api_key" password="True"/>
                            <div class="text-muted mt4">
                                <a href="https://aistudio.google.com/" target="_blank">Get your API Key here</a>
                            </div>
                            <group>
                                <button name="action_test_gemini_api_key"
                                        string="Test Connection"
                                        type="object"
                                        class="btn-primary"/>
                            </group>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_content_generator_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'content_generator'}</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_contentgenerator_settings"
              name="Settings"
              parent="menu_contentgenerator_configuration"
              action="action_content_generator_config_settings"
              sequence="99"/>
</odoo>
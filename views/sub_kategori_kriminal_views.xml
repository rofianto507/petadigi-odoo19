<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_petadigi_sub_kategori_kriminal_list" model="ir.ui.view">
            <field name="name">sub_kategori_kriminal.list.petadigi</field>
            <field name="model">petadigi.sub_kategori_kriminal</field>
            <field name="arch" type="xml">
                <list string="Sub Kategori Kriminal">
                    <field name="name"/>
                    <field name="kategori_kriminal_id"/>
                    <field name="keterangan"/>
                </list>
            </field>
        </record>
        <record id="view_petadigi_sub_kategori_kriminal_form" model="ir.ui.view">
            <field name="name">sub_kategori_kriminal.form.petadigi</field>
            <field name="model">petadigi.sub_kategori_kriminal</field>
            <field name="arch" type="xml">
                <form string="Sub Kategori Kriminal">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="kategori_kriminal_id"/>
                            <field name="keterangan"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_petadigi_sub_kategori_kriminal" model="ir.actions.act_window">
            <field name="name">Sub Kategori Kriminal</field>
            <field name="res_model">petadigi.sub_kategori_kriminal</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
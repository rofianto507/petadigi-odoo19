<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_petadigi_polsek_list" model="ir.ui.view">
            <field name="name">polsek.list.petadigi</field>
            <field name="model">petadigi.polsek</field>
            <field name="arch" type="xml">
                <list string="Polsek">
                    <field name="name"/>
                    <field name="address"/>
                    <field name="polres_id"/>
                </list>
            </field>
        </record>
        <record id="view_petadigi_polsek_form" model="ir.ui.view">
            <field name="name">polsek.form.petadigi</field>
            <field name="model">petadigi.polsek</field>
            <field name="arch" type="xml">
                <form string="Polsek">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="address"/>
                            <field name="polres_id"/>
                        </group>
                        <notebook>
                            <page string="Daftar Kecamatan">
                                <field name="kecamatan_ids">
                                    <list editable="bottom">
                                        <field name="code"/>
                                        <field name="name"/>
                                        <field name="kabupaten_id"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_petadigi_polsek" model="ir.actions.act_window">
            <field name="name">Polsek</field>
            <field name="res_model">petadigi.polsek</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
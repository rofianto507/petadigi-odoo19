<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_petadigi_kategori_kamtibmas_list" model="ir.ui.view">
            <field name="name">kategori_kamtibmas.list.petadigi</field>
            <field name="model">petadigi.kategori_kamtibmas</field>
            <field name="arch" type="xml">
                <list string="Kategori Kamtibmas">
                    <field name="name"/>
                    <field name="keterangan"/>
                </list>
            </field>
        </record>
        <record id="view_petadigi_kategori_kamtibmas_form" model="ir.ui.view">
            <field name="name">kategori_kamtibmas.form.petadigi</field>
            <field name="model">petadigi.kategori_kamtibmas</field>
            <field name="arch" type="xml">
                <form string="Kategori Kamtibmas">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="keterangan"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_petadigi_kategori_kamtibmas" model="ir.actions.act_window">
            <field name="name">Kategori Kamtibmas</field>
            <field name="res_model">petadigi.kategori_kamtibmas</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
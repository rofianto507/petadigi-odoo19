<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_petadigi_polres_list" model="ir.ui.view">
            <field name="name">polres.list.petadigi</field>
            <field name="model">petadigi.polres</field>
            <field name="arch" type="xml">
                <list string="Polres">
                    <field name="name"/>
                    <field name="address"/>
                </list>
            </field>
        </record>
        <record id="view_petadigi_polres_form" model="ir.ui.view">
            <field name="name">polres.form.petadigi</field>
            <field name="model">petadigi.polres</field>
            <field name="arch" type="xml">
                <form string="Polres">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="address"/>
                        </group>
                         <notebook>
                            <page string="Daftar Polsek">
                                <field name="polsek_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="address"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_petadigi_polres" model="ir.actions.act_window">
            <field name="name">Polres</field>
            <field name="res_model">petadigi.polres</field>
            <field name="view_mode">list,form</field>
        </record>
        
    </data>
</odoo>
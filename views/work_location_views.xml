<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List View (Sudah Benar) -->
        <record id="view_work_location_list_smartatt" model="ir.ui.view">
            <field name="name">hr.work.location.list.smartatt</field>
            <field name="model">hr.work.location</field>
            <field name="arch" type="xml">
                <list string="Work Locations">
                    <field name="name"/>
                    <field name="latitude"/>
                    <field name="longitude"/>
                    <field name="radius"/>
                    <field name="address_id"/>
                </list>
            </field>
        </record>
        
        <!-- Form View (Sudah Benar) -->
         <record id="view_work_location_form_smartatt" model="ir.ui.view">
            <field name="name">hr.work.location.form.smartatt</field>
            <field name="model">hr.work.location</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="e.g. Head Office"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="address_id" context="{'show_address': 1}" options="{&quot;always_reload&quot;: True}"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <!-- Field ini disembunyikan karena diatur oleh peta -->
                                <field name="latitude" invisible="1"/>
                                <field name="longitude" invisible="1"/>
                            </group>
                        </group>
                        
                        <!-- WIDGET PETA DITERAPKAN DI SINI -->
                        <!-- Ditempatkan langsung di bawah sheet untuk lebar penuh -->
                        <div>
                            <field name="latitude" widget="location_picker" nolabel="1" class="o_field_map_full_width"/>
                        </div>
                        <group string="Geofencing Details">
                            <field name="latitude" readonly="1"/>
                            <field name="longitude" readonly="1"/>
                            <field name="radius" widget="integer"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action untuk Work Locations (DIPERBAIKI) -->
        <record id="action_smart_attendance_work_locations" model="ir.actions.act_window">
            <field name="name">Work Locations</field>
            <field name="res_model">hr.work.location</field>
            <field name="view_mode">list,form</field>
            <!-- PERBAIKAN DI SINI: Tambahkan referensi ke form view kustom -->
            <field name="view_ids" eval="[(5, 0, 0), 
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_work_location_list_smartatt')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_work_location_form_smartatt')})
            ]"/>
        </record>
    </data>
</odoo>
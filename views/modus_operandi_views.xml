<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_petadigi_modus_operandi_list" model="ir.ui.view">
            <field name="name">modus_operandi.list.petadigi</field>
            <field name="model">petadigi.modus_operandi</field>
            <field name="arch" type="xml">
                <list string="Modus Operandi">
                    <field name="name"/>
                    <field name="keterangan"/>
                </list>
            </field>
        </record>
        <record id="view_petadigi_modus_operandi_form" model="ir.ui.view">
            <field name="name">modus_operandi.form.petadigi</field>
            <field name="model">petadigi.modus_operandi</field>
            <field name="arch" type="xml">
                <form string="Modus Operandi">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="keterangan"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_petadigi_modus_operandi" model="ir.actions.act_window">
            <field name="name">Modus Operandi</field>
            <field name="res_model">petadigi.modus_operandi</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
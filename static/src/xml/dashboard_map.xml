<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="petadigi.DashboardMap">
        <div class="petadigi-dashboard">

            <!-- ── TOOLBAR TOP ── -->
            <div class="petadigi-toolbar">
                <div class="petadigi-toolbar-left">
                    <button class="petadigi-sidebar-toggle" t-on-click="onToggleSidebar">
                        <i class="fa fa-bars"/>
                    </button>
                    <span class="petadigi-toolbar-title">
                        <i class="fa fa-map" style="margin-right:6px;"/>
                        PetaDigi — Peta Digital Provinsi Sumsel
                    </span>
                </div>
                <div class="petadigi-toolbar-right">
                    <div class="petadigi-filter-group">
                        <i class="fa fa-filter"/>
                        <select class="petadigi-select" t-ref="filterTahun" t-on-change="onFilterChange">
                            <option value="">Semua Tahun</option>
                        </select>
                        <select class="petadigi-select" t-ref="filterKabupaten" t-on-change="onFilterChange">
                            <option value="">Semua Kabupaten</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- ── MAIN AREA ── -->
            <div class="petadigi-main">

                <!-- SIDEBAR -->
                <div class="petadigi-sidebar" t-ref="sidebar">
                    <div class="petadigi-sidebar-section-title">PETA</div>
                    <nav class="petadigi-nav">
                        <a class="petadigi-nav-item active" data-mode="umum" t-on-click="onNavClick">
                            <i class="fa fa-map"/>
                            <span>Peta Umum</span>
                        </a>
                        <a class="petadigi-nav-item" data-mode="kriminal" t-on-click="onNavClick">
                            <i class="fa fa-exclamation-triangle"/>
                            <span>Peta Kriminal</span>
                            <span class="petadigi-nav-badge petadigi-nav-badge--red" t-ref="badgeKriminal">0</span>
                        </a>
                        <a class="petadigi-nav-item" data-mode="lalin" t-on-click="onNavClick">
                            <i class="fa fa-car"/>
                            <span>Peta Lalu Lintas</span>
                            <span class="petadigi-nav-badge petadigi-nav-badge--orange" t-ref="badgeLatlin">0</span>
                        </a>
                        <a class="petadigi-nav-item" data-mode="bencana" t-on-click="onNavClick">
                            <i class="fa fa-bolt"/>
                            <span>Peta Bencana</span>
                            <span class="petadigi-nav-badge petadigi-nav-badge--blue" t-ref="badgeBencana">0</span>
                        </a>
                        <a class="petadigi-nav-item" data-mode="lokasi" t-on-click="onNavClick">
                            <i class="fa fa-map-marker"/>
                            <span>Lokasi Penting</span>
                            <span class="petadigi-nav-badge petadigi-nav-badge--green" t-ref="badgeLokasi">0</span>
                        </a>
                    </nav>

                    <div class="petadigi-sidebar-footer">
                        <button class="petadigi-sidebar-collapse-btn" t-on-click="onToggleSidebar">
                            <i class="fa fa-chevron-left" t-ref="collapseIcon"/>
                            <span t-ref="collapseText">Sembunyikan</span>
                        </button>
                    </div>
                </div>

                <!-- MAP AREA -->
                <div class="petadigi-map-wrapper">
                    <!-- Breadcrumb level -->
                    <div class="petadigi-breadcrumb" t-ref="breadcrumb">
                        <span class="petadigi-breadcrumb-item active">
                            <i class="fa fa-map"/> Peta Umum
                        </span>
                    </div>
                    <!-- tabindex="-1" mencegah browser scroll saat map diklik -->
                    <div t-ref="mapContainer" class="petadigi-map-container" tabindex="-1"/>
                </div>

            </div>
        </div>
    </t>
</templates>

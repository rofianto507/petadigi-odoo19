<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- 
        t-inherit-mode="extension" : memodifikasi template web.ListController secara langsung
        tanpa membuat template baru, sehingga tidak ada error "missing template".
        t-if guard memastikan tombol hanya muncul di list view kriminalitas.
    -->
    <t t-name="petadigi.KriminalitasListController"
       t-inherit="web.ListController"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_control_panel_actions')]" position="inside">
            <button t-if="model.config.resModel === 'petadigi.kriminalitas'"
                    class="btn btn-secondary"
                    t-on-click="openImportWizard">
                Import LP
            </button>
        </xpath>
    </t>
</templates>

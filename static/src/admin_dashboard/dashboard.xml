<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hr_smartatt.DashboardTemplate">
        <div class="o_action_manager overflow-auto p-4" style="background-color: #f1f3f4; height: 100vh;">
            <div class="d-flex justify-content-between mb-4">
                <h2 class="fw-bold">Smart Attendance Dashboard</h2>
                <button class="btn btn-primary" t-on-click="loadData">
                    <i class="fa fa-refresh"/> Refresh
                </button>
            </div>

            <div class="row g-3 mb-4">
                <!-- Card 1: Total Employees -->
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="card shadow-sm border-0 h-100" t-on-click="() => this.openView('employees')" style="cursor: pointer;">
                        <div class="card-body text-center">
                            <h5 class="text-muted">Total Employees</h5>
                            <h1 class="display-4 fw-bold text-primary"><t t-esc="state.stats.total_employees"/></h1>
                        </div>
                    </div>
                </div>

                <!-- 2. Total Work Locations (BARU) -->
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="card shadow-sm border-0 h-100" t-on-click="() => this.openView('locations')" style="cursor: pointer;">
                        <div class="card-body text-center">
                            <h5 class="text-muted">Work Locations</h5>
                            <h1 class="display-4 fw-bold text-info"><t t-esc="state.stats.total_locations"/></h1>
                        </div>
                    </div>
                </div>

                <!-- 3. Present Today -->
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="card shadow-sm border-0 h-100" t-on-click="() => this.openView('present')" style="cursor: pointer;">
                        <div class="card-body text-center">
                            <h5 class="text-muted">Present Today</h5>
                            <h1 class="display-4 fw-bold text-success"><t t-esc="state.stats.present_count"/></h1>
                        </div>
                    </div>
                </div>

                <!-- 4. Absent -->
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <h5 class="text-muted">Absent</h5>
                            <h1 class="display-4 fw-bold text-danger"><t t-esc="state.stats.absent_count"/></h1>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white py-3">
                            <h6 class="mb-0 fw-bold text-dark">Location Distribution (Today)</h6>
                        </div>
                        <div class="card-body d-flex align-items-center justify-content-center">
                            <div style="height: 250px; width: 100%;">
                                <!-- Canvas Donut -->
                                <canvas t-ref="locationChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-lg-9">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white py-3">
                            <h6 class="mb-0 fw-bold text-dark">Weekly Attendance Rate (%)</h6>
                        </div>
                        <div class="card-body">
                            <div style="height: 250px; width: 100%;">
                                <!-- Canvas Line -->
                                <canvas t-ref="lineChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>